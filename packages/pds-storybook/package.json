{
  "name": "@pure-ds/storybook",
  "version": "0.7.81",
  "description": "Storybook showcase for Pure Design System with live configuration",
  "type": "module",
  "private": false,
  "bin": {
    "pds-storybook": "./bin/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "bin",
    ".storybook",
    "scripts",
    "src",
    "public",
    "stories",
    "dist",
    "pds.config.js",
    "default-pds.config.js"
  ],
  "scripts": {
    "generate-stories": "node scripts/generate-stories.js",
    "build-reference": "node --no-warnings=ExperimentalWarning scripts/build-pds-reference.mjs",
    "copy-getting-started": "node scripts/copy-getting-started.js",
    "package-build": "node scripts/package-build.js",
    "package-clean": "node -e \"const fs=require('fs'); fs.rmSync('src',{recursive:true,force:true}); fs.rmSync('public/assets',{recursive:true,force:true}); console.log('Cleaned package artifacts')\"",
    "prepack": "npm run package-build",
    "postpack": "npm run package-clean",
    "storybook": "npm run copy-getting-started && npm run build-reference && storybook dev -p 6006",
    "build-storybook": "npm run copy-getting-started && npm run build-reference && storybook build --output-dir storybook-static --quiet",
    "storybook:dev": "npm run storybook",
    "storybook:build": "npm run build-storybook",
    "pds:build": "pds-build",
    "pds:build-icons": "pds-build-icons",
    "pds:import": "pds-import",
    "pds:mcp:server": "pds-mcp-server",
    "pds:mcp:health": "pds-mcp-health",
    "pds:mcp:eval": "pds-mcp-eval",
    "pds:bootstrap": "pds-bootstrap"
  },
  "peerDependencies": {
    "@pure-ds/core": "^0.7.81"
  },
  "dependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/web-components": "^8.6.18",
    "@storybook/web-components-vite": "^8.6.18",
    "lit": "^3.3.1",
    "marked": "^15.0.12",
    "storybook": "^8.6.18",
    "vite": "^5.4.0"
  },
  "imports": {
    "#pds": "@pure-ds/core",
    "#pds/lit": "@pure-ds/core/lit"
  }
}
